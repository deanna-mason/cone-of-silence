# Long random string (16+ chars); the admin page's paste-to-unlock secret.
# Generate one: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
ADMIN_SECRET=

# file | supabase
TOKEN_STORE=file
TOKEN_FILE=data/tokens.json

# Required always: accounts + studio (recordings) are Supabase-backed even
# when TOKEN_STORE=file.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:3000

PORT=8787

# Studio (recording upload/enhance pipeline):
# Where uploaded/processed audio + waveforms are stored on disk.
UPLOAD_DIR=data/uploads
# Path to the RNNoise model used by the arnndn ffmpeg filter.
RNNOISE_MODEL=models/std.rnnn
